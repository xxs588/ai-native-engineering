{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "build:e2e": "NEXT_FONT_GOOGLE_MOCKED_RESPONSES=$PWD/scripts/next-font-google-mocks.cjs GITHUB_REPOSITORY=TatsukiMeng/ai-native-engineering next build --debug-build-paths 'src/app/e2e/copy-markdown/page.tsx,src/app/e2e/copy-markdown/source.mdx/route.ts'",
    "dev": "next dev",
    "start": "serve out",
    "test:e2e": "playwright test",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "bunx oxlint .",
    "format": "bunx oxfmt --write ."
  },
  "dependencies": {
    "@giscus/react": "^3.1.0",
    "@orama/orama": "^3.1.18",
    "fumadocs-core": "^16.6.7",
    "fumadocs-mdx": "14.2.8",
    "fumadocs-ui": "16.6.7",
    "lucide-react": "^0.575.0",
    "mermaid": "^11.12.3",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-directive": "^4.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.6",
    "serve": "^14.2.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
